{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "./.tsbuildinfo-node",
    "types": ["node"]
  },
  "include": ["vite.config.ts", "vitest.config.ts", "playwright.browser.config.ts"]
}
